<main class="resume-container" style="max-width:1100px;margin:40px auto;padding:0 20px;">

  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <a href="/" style="text-decoration:none;color:#a855f7;font-weight:600;">⬅ Back to Portfolio</a>
    <% if (resumeUrl) { %>
      <a href="<%= resumeUrl %>" target="_blank" class="btn-primary-ag">⬇ Download Resume</a>
    <% } %>
  </div>

  <div style="width:100%;height:85vh;border-radius:12px;overflow:hidden;border:1px solid rgba(124,58,237,0.2);">
    <% if (resumeUrl) { %>
      <iframe
        src="https://docs.google.com/viewer?url=<%= encodeURIComponent(resumeUrl) %>&embedded=true"
        width="100%"
        height="100%"
        style="border:none;"
        onload="clearTimeout(retryTimer)"
        id="resumeFrame">
      </iframe>

      <!-- Auto-retry if Google Docs Viewer fails to load -->
      <script>
        let retries = 0;
        const maxRetries = 3;
        const frame = document.getElementById("resumeFrame");

        let retryTimer = setTimeout(function retry() {
          if (retries < maxRetries) {
            retries++;
            console.log("Retrying PDF load... attempt", retries);
            frame.src = frame.src;
            retryTimer = setTimeout(retry, 3000);
          }
        }, 4000);
      </script>

    <% } else { %>
      <div style="
        display:flex;flex-direction:column;
        justify-content:center;align-items:center;
        height:100%;color:#64748b;gap:1rem;
        background:#081f38;
      ">
        <div style="font-size:3rem;">📄</div>
        <h3 style="color:#f0f0ff;">No Resume Linked</h3>
        <p style="font-size:0.88rem;">Add a resume link from the
          <a href="/admin" style="color:#a78bfa;">admin dashboard</a>.
        </p>
      </div>
    <% } %>
  </div>

</main>